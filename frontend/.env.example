# Copy this file to `.env.local` (preferred) or `.env` and adjust the value if
# your backend is bound to a different host/port.
#
# Required in dev. The frontend uses this for two things:
#   1. Vite's HTTP proxy for `/api/*`.
#   2. The direct backend WebSocket base used by useAgentStream.
#
# IMPORTANT: do not use `localhost` on macOS. macOS resolves `localhost` to
# IPv6 `::1` first, and uvicorn `--host 127.0.0.1` listens on IPv4 only, so
# Chrome's WebSocket client hits "Connection refused" on `::1:8000` and the
# UI gets stuck in "Reconnecting to live stream". Use the explicit IPv4
# address instead:
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
