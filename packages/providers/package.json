{
  "name": "@socrates/providers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "pnpm --filter @socrates/shared build && pnpm --filter @socrates/contracts build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai": "^3.0.64",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@socrates/contracts": "workspace:*",
    "@socrates/shared": "workspace:*",
    "ai": "^6.0.185",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "vitest": "^4.0.15"
  }
}
